<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.smartisan.weather.widget.MenuDialogTitleBar
        android:id="@+id/menu_dialog_title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <View
        android:background="@color/divider_listview"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/contentPanel"
        android:background="@color/app_dialog_surface_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ListView
            android:scrollbarStyle="outsideOverlay"
            android:id="@+id/content_list"
            android:paddingLeft="@dimen/menu_dialog_horizontal_distance"
            android:paddingTop="24dp"
            android:paddingRight="@dimen/menu_dialog_horizontal_distance"
            android:paddingBottom="24dp"
            android:visibility="gone"
            android:scrollbars="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:listSelector="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="18dp"
            android:overScrollMode="never"/>
        <com.smartisan.weather.widget.ShadowButton
            android:textSize="13.5sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:id="@+id/btn_ok"
            android:background="@drawable/shrink_long_btn_red_selector"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginLeft="@dimen/menu_dialog_horizontal_distance"
            android:layout_marginTop="24dp"
            android:layout_marginRight="@dimen/menu_dialog_horizontal_distance"
            android:layout_marginBottom="24dp"
            android:singleLine="true"/>
    </LinearLayout>
</LinearLayout>
