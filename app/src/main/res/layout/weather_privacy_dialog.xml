<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/privacy_dialog_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/app_surface_raised_color"
        android:gravity="center"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/privacy_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/weather_request_location_permission_tips_title"
            android:textColor="@color/app_secondary_text_color"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/app_divider_color" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:fillViewport="true">

        <TextView
            android:id="@+id/privacy_dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:lineSpacingMultiplier="1.1"
            android:minHeight="96dp"
            android:paddingLeft="20dp"
            android:paddingTop="18dp"
            android:paddingRight="18dp"
            android:paddingBottom="18dp"
            android:textColor="@color/app_secondary_text_color"
            android:textSize="13sp" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/app_divider_color" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/app_surface_raised_color"
        android:baselineAligned="false"
        android:divider="@drawable/dialog_line_smartisanos"
        android:gravity="center"
        android:orientation="horizontal"
        android:showDividers="middle">

        <Button
            android:id="@+id/privacy_dialog_negative"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/privacy_dialog_button_left_bg"
            android:backgroundTint="@null"
            android:elevation="0dp"
            android:gravity="center"
            android:maxLines="2"
            android:minHeight="48dp"
            android:stateListAnimator="@null"
            android:text="@string/weather_privacy_statement_tip_disagress"
            android:textColor="@color/privacy_dialog_negative_text"
            android:textSize="13.5sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/privacy_dialog_positive"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/privacy_dialog_button_right_bg"
            android:backgroundTint="@null"
            android:elevation="0dp"
            android:gravity="center"
            android:maxLines="2"
            android:minHeight="48dp"
            android:stateListAnimator="@null"
            android:text="@string/weather_privacy_statement_tip_agree"
            android:textColor="@color/privacy_dialog_positive_text"
            android:textSize="13.5sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
