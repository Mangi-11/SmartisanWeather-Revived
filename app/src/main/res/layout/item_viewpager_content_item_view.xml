<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="108dp"
    android:minWidth="@dimen/item_pager_content_forcast_hour_item_view_width"
    android:importantForAccessibility="no">
    <TextView
        android:textSize="@dimen/item_pager_content_forcast_hour_item_view_text_size"
        android:textStyle="bold"
        android:textColor="@color/item_pager_content_forcast_hour_item_view_text_color"
        android:gravity="center_vertical"
        android:id="@+id/item_view_time"
        android:layout_width="wrap_content"
        android:layout_height="20dp"/>
    <ImageView
        android:id="@+id/item_view_img"
        android:layout_width="30dp"
        android:layout_height="48dp"/>
    <com.smartisan.weather.custom.WeatherTempAnimView
        android:id="@+id/viewflipper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/item_pager_content_forcast_hour_item_view_text_size"
            android:textStyle="bold"
            android:textColor="@color/item_pager_content_forcast_hour_item_view_text_color"
            android:gravity="center_vertical"
            android:layout_gravity="center"
            android:id="@+id/item_view_tmpc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="@dimen/item_pager_content_forcast_hour_item_view_text_size"
            android:textStyle="bold"
            android:textColor="@color/item_pager_content_forcast_hour_item_view_text_color"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/item_view_tmpf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </com.smartisan.weather.custom.WeatherTempAnimView>
</LinearLayout>
