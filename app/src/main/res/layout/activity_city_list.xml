<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/city_list_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/list_bg">

    <com.smartisan.weather.custom.WeatherListView
        android:id="@+id/dragsortlistview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/top_bar_surface"
        android:clipToPadding="false"
        android:divider="@null"
        android:listSelector="@android:color/transparent"
        android:overScrollMode="always"
        app:adjust_item_animation_duration="200"
        app:click_remove_id="@id/delete"
        app:collapsed_height="1px"
        app:drag_enabled="true"
        app:drag_handle_id="@id/drag"
        app:drag_scroll_start="0.25"
        app:drag_start_mode="onDown"
        app:drop_animation_duration="150"
        app:float_alpha="1"
        app:max_drag_scroll_speed="0.5"
        app:slide_shuffle_speed="1" />

    <com.smartisan.weather.widget.InsetTopBarLayout
        android:id="@+id/top_bar_surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/app_top_bar_background">

        <com.smartisan.weather.widget.TitleBar
            android:id="@+id/title_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/titlebar_height" />
    </com.smartisan.weather.widget.InsetTopBarLayout>

    <ImageView
        android:id="@+id/title_bar_shadow_view"
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_bar_shadow_height"
        android:layout_below="@id/top_bar_surface"
        android:background="@drawable/title_bar_shadow"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />
</RelativeLayout>
